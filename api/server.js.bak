@'
import Fastify from "fastify";
import cors from "@fastify/cors";
import cookie from "@fastify/cookie";
import websocket from "@fastify/websocket";
import { nanoid } from "nanoid";
import argon2 from "argon2";
import pg from "pg";

const { Pool } = pg;

const PORT = Number(process.env.PORT || 3000);
const DATABASE_URL =
  process.env.DATABASE_URL ||
  "postgres://postgres:postgres@postgres:5432/postgres";
const JWT_SECRET = process.env.JWT_SECRET || "change-me";

function b64urlEncode(obj) {
  return Buffer.from(JSON.stringify(obj)).toString("base64url");
}
function signToken(payload) {
  const header = { alg: "HS256", typ: "JWT" };
  const body = { ...payload, iat: Math.floor(Date.now() / 1000) };
  const base = `${b64urlEncode(header)}.${b64urlEncode(body)}`;
  const sig = require("crypto")
    .createHmac("sha256", JWT_SECRET)
    .update(base)
    .digest("base64url");
  return `${base}.${sig}`;
}
function verifyToken(token) {
  const parts = String(token || "").split(".");
  if (parts.length !== 3) return null;
  const [h, p, s] = parts;
  const base = `${h}.${p}`;
  const sig = require("crypto")
    .createHmac("sha256", JWT_SECRET)
    .update(base)
    .digest("base64url");
  if (sig !== s) return null;
  try {
    return JSON.parse(Buffer.from(p, "base64url").toString("utf8"));
  } catch {
    return null;
  }
}

const app = Fastify({ logger: true });

const pool = new Pool({ connectionString: DATABASE_URL });

async function initDb() {
  await pool.query(`
    CREATE TABLE IF NOT EXISTS users (
      id TEXT PRIMARY KEY,
      username TEXT UNIQUE NOT NULL,
      passhash TEXT NOT NULL,
      created_at TIMESTAMPTZ NOT NULL DEFAULT NOW()
    );
  `);

  await pool.query(`
    CREATE TABLE IF NOT EXISTS messages (
      id TEXT PRIMARY KEY,
      user_id TEXT NOT NULL REFERENCES users(id) ON DELETE CASCADE,
      text TEXT NOT NULL,
      created_at TIMESTAMPTZ NOT NULL DEFAULT NOW()
    );
  `);
}

app.register(cors, {
  origin: true,
  credentials: true
});
app.register(cookie);
app.register(websocket);

app.get("/health", async () => ({ ok: true }));

app.post("/auth/register", async (req, reply) => {
  const { username, password } = req.body || {};
  if (!username || !password) {
    return reply.code(400).send({ error: "username_and_password_required" });
  }

  const id = nanoid(16);
  const passhash = await argon2.hash(String(password));

  try {
    await pool.query(
      "INSERT INTO users(id, username, passhash) VALUES($1,$2,$3)",
      [id, String(username), passhash]
    );
  } catch (e) {
    if (String(e?.code) === "23505") {
      return reply.code(409).send({ error: "username_taken" });
    }
    req.log.error(e);
    return reply.code(500).send({ error: "db_error" });
  }

  const token = signToken({ sub: id, username: String(username) });
  return { token };
});

app.post("/auth/login", async (req, reply) => {
  const { username, password } = req.body || {};
  if (!username || !password) {
    return reply.code(400).send({ error: "username_and_password_required" });
  }

  const r = await pool.query(
    "SELECT id, username, passhash FROM users WHERE username=$1",
    [String(username)]
  );
  if (r.rowCount === 0) return reply.code(401).send({ error: "bad_credentials" });

  const user = r.rows[0];
  const ok = await argon2.verify(user.passhash, String(password));
  if (!ok) return reply.code(401).send({ error: "bad_credentials" });

  const token = signToken({ sub: user.id, username: user.username });
  return { token };
});

app.get("/me", async (req, reply) => {
  const auth = req.headers.authorization || "";
  const token = auth.startsWith("Bearer ") ? auth.slice(7) : "";
  const payload = verifyToken(token);
  if (!payload) return reply.code(401).send({ error: "unauthorized" });
  return { id: payload.sub, username: payload.username };
});

// WebSocket: ws://host/ws?token=...
const clients = new Set();

app.get("/ws", { websocket: true }, (connection, req) => {
  const url = new URL(req.url, "http://localhost");
  const token = url.searchParams.get("token");
  const payload = verifyToken(token);
  if (!payload) {
    connection.socket.close();
    return;
  }

  const client = { socket: connection.socket, user: payload };
  clients.add(client);

  connection.socket.on("message", async (buf) => {
    const text = String(buf || "").slice(0, 2000);
    if (!text) return;

    const msgId = nanoid(16);
    await pool.query(
      "INSERT INTO messages(id, user_id, text) VALUES($1,$2,$3)",
      [msgId, payload.sub, text]
    );

    const out = JSON.stringify({
      id: msgId,
      user: payload.username,
      text,
      ts: Date.now()
    });

    for (const c of clients) {
      try { c.socket.send(out); } catch {}
    }
  });

  connection.socket.on("close", () => {
    clients.delete(client);
  });
});

await initDb();

app.listen({ port: PORT, host: "0.0.0.0" });
'@ | Set-Content -Encoding UTF8 server.js